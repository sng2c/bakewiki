# bakewiki 환경변수

# 데이터 디렉토리 (필수). --data 플래그로도 지정 가능.
# 문서는 pages/ 서브디렉토리에 .md 파일로 저장
# 설정은 config.yml, 인증은 auth.json 에 저장
BAKEWIKI_DATA_DIR=

# 서버 포트 (기본값: 3000)
BAKEWIKI_PORT=3000

# 바인드 호스트 (기본값: 127.0.0.1, 로컬 전용)
# 외부 접속을 허용하려면 0.0.0.0 으로 설정
BAKEWIKI_HOST=127.0.0.1

# 원격 명령용 서버 URL (기본값: http://127.0.0.1:3000)
BAKEWIKI_URL=http://127.0.0.1:3000

# 원격 명령용 API 키 (bakewiki remote 명령에서 사용)
BAKEWIKI_API_KEY=

# admin create non-TTY(헤드리스/CI) 전용. TTY에서는 인터랙티브 프롬프트 사용.
BAKEWIKI_ADMIN_EMAIL=
BAKEWIKI_ADMIN_PASSWORD=