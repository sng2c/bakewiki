# bakewiki 환경변수

# 서버 포트 (기본값: 3000)
BAKEWIKI_PORT=3000

# SQLite DB 파일 경로 (기본값: ~/.bakewiki/data/bakewiki.db)
BAKEWIKI_DB_PATH=

# JWT 서명 비밀키 (필수). 긴 랜덤 문자열 사용.
# 예: openssl rand -hex 32
BAKEWIKI_JWT_SECRET=

# init non-TTY(헤드리스/CI) 전용. TTY에서는 인터랙티브 프롬프트 사용.
BAKEWIKI_ADMIN_EMAIL=
BAKEWIKI_ADMIN_PASSWORD=
