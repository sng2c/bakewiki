{
  "name": "@sng2c/bakewiki",
  "version": "0.2.2",
  "description": "An open-source GFM wiki for humans and LLMs",
  "type": "module",
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/sng2c/bakewiki.git"
  },
  "homepage": "https://github.com/sng2c/bakewiki",
  "bugs": {
    "url": "https://github.com/sng2c/bakewiki/issues"
  },
  "bin": {
    "bakewiki": "dist/cli.js"
  },
  "files": [
    "dist",
    "public",
    "README.md",
    "README.ko.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "init": "tsx src/cli.ts init --data ./data",
    "serve": "tsx src/cli.ts serve --data ./data",
    "admin:create": "tsx src/cli.ts admin create --data ./data",
    "build": "tsc && vite build && cp dist/public/page.js dist/public/editor.js public/",
    "serve:prod": "node dist/cli.js serve --data ./data"
  },
  "dependencies": {
    "@hono/node-server": "2.0.6",
    "bcrypt": "6.0.0",
    "dotenv": "17.4.2",
    "handlebars": "4.7.9",
    "hono": "4.12.27",
    "jose": "6.2.3",
    "yaml": "2.9.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/bcrypt": "6.0.0",
    "@types/node": "26.0.1",
    "playwright": "^1.61.1",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vite": "^8.1.2"
  }
}
